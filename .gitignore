# PING-007 Framework .gitignore

# Binaries (Go)
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out
coverage.html
coverage.out

# Build artifacts
/build/
/dist/
ping-007
ping-007-*

# Go workspace file
go.work
go.work.sum

# Go modules download cache
/vendor/

# Dependency directories
node_modules/

# Logs and temporary files
*.log
/logs/
*.tmp
*.temp
.DS_Store
Thumbs.db

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Documentation artifacts (AI assistant files)
CLAUDE.md
DOCS.md
*.old
*.backup
*.bak

# Framework specific
/received/
/reports/
/loot/
/captures/
/output/
/archive/
benchmark.out

# Config files with credentials
config/**/secrets.yml
config/**/*.key
config/**/*.pem
*.env
.env.*

# Temporary make files
Makefile.old
Makefile.backup

# UPX backups
*.upx.bak

# Test data
test_data/
testdata/
mock_*
dummy_*

# Compressed archives
*.tar.gz
*.zip
*.7z
*.rar

# Database files
*.db
*.sqlite
*.sqlite3

# Certificate files
*.crt
*.cer
*.p12
*.pfx